<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="https://jakarta.ee/xml/ns/jakartaee"
	xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
	id="WebApp_ID" version="5.0">

	<servlet>
		<servlet-name>MyServletInterafce</servlet-name>
		<servlet-class>com.myservice.MyServletInterafce</servlet-class>
	</servlet>

	<servlet-mapping>
		<servlet-name>MyServletInterafce</servlet-name>
		<url-pattern>/csea</url-pattern>
	</servlet-mapping>
	
	
	<servlet>
		<servlet-name>MyGenericServlet</servlet-name>
		<servlet-class>com.myservice.MyGenericServlet</servlet-class>
	</servlet>

	<servlet-mapping>
		<servlet-name>MyGenericServlet</servlet-name>
		<url-pattern>/cseb</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<servlet-name>MyHttpServlet</servlet-name>
		<servlet-class>com.myservice.MyHttpServlet</servlet-class>
	</servlet>

	<servlet-mapping>
		<servlet-name>MyHttpServlet</servlet-name>
		<url-pattern>/csec</url-pattern>
	</servlet-mapping>
</web-app>